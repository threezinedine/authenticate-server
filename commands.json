[
    {
        "name": "storybook",
        "cwd": "server/frontend",
        "command": "npm run storybook"
    },
    {
        "name": "run server",
        "cwd": "server",
        "command": "ENVIRONMENT=development && uv run server.py"
    },
    {
        "name": "start windows",
        "cwd": "server",
        "command": "docker-compose up"
    },
    {
        "name": "stop windows",
        "cwd": "server",
        "command": "docker-compose down"
    },
    {
        "name": "start linux",
        "cwd": "server",
        "command": "docker compose up"
    },
    {
        "name": "stop linux",
        "cwd": "server",
        "command": "docker compose down"
    },
    {
        "name": "test e2e chrome",
        "cwd": "",
        "command": "npm run test:e2e:chrome"
    },
    {
        "name": "test e2e firefox",
        "cwd": "",
        "command": "npm run test:e2e:firefox"
    },
    {
        "name": "test e2e edge",
        "cwd": "",
        "command": "npm run test:e2e:edge"
    },
    {
        "name": "dev e2e",
        "cwd": "",
        "command": "npm run dev:e2e"
    },
    {
        "name": "test components",
        "cwd": "server/frontend",
        "command": "npm run test",
        "forceInline": true
    },
    {
        "name": "test server",
        "cwd": "server",
        "command": "uv run pytest tests",
        "forceInline": true
    }
]