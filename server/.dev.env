# Database Configuration (Docker Compose MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=devuser
MYSQL_PASSWORD=devpassword
MYSQL_DB=dev_auth_db

# JWT & Crypto Configuration
JWT_ALGORITHM=RS256
RSA_PRIVATE_KEY_PATH=./secrets/dev_private_key.pem 

# Local Avatar Storage Configuration
AVATAR_UPLOAD_DIR=./uploads/avatars

# General Server Setting
ENVIRONMENT=development
PORT=8000
