# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/auth_db

# JWT & Crypto Configuration
JWT_ALGORITHM=RS256
# The path or actual string of your private key used to sign JWTs
RSA_PRIVATE_KEY_PATH=/etc/secrets/private_key.pem 

# Local Avatar Storage Configuration
AVATAR_UPLOAD_DIR=./uploads/avatars

# General Server Setting
ENVIRONMENT=development
PORT=8000
