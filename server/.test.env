# Database Configuration
# Testing utilizes an automatic in-memory SQLite database, so no variables are needed here

# JWT & Crypto Configuration
JWT_ALGORITHM=RS256
RSA_PRIVATE_KEY_PATH=/etc/secrets/test_private_key.pem 

# Local Avatar Storage Configuration
AVATAR_UPLOAD_DIR=/tmp/auth_test_avatars

# General Server Setting
ENVIRONMENT=test
PORT=8000
